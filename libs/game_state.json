      "modifiers_applied": [
        {
          "modifier_id": "MOD-EW-001",
          "name": "GPS-Denied Environment",
          "field_affected": "attack.power",
          "operator": "MULTIPLY",
          "value": 0.65,
          "source": "RAND RR4229",
          "power_after": 59.8
        }
      ],
      "final_attack_power": 59.8,
      "target_armor": 30,
      "damage_dealt": 29.8,
      "formula": "(92 × 0.65) - 30 = 29.8",
      "defender_hp_before": 5,
      "defender_hp_after": 4,
      "defender_status_after": "DAMAGED",
      "narrative": "F-35A Strike Wing attacks PLA Amphibious Assault Group in the Strait. GPS jamming degrades precision guidance (RAND RR4229 — MOD-EW-001). Effective strike power reduced from 92 to 59.8. Armor absorbs 30. Net damage: 29.8."
    }
