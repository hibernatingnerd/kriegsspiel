{
  "metadata": {
    "version": "2.0",
    "description": "Starter kit scenario library. Three scenario types — Land, Amphibious, Urban. Locations are generic node labels. Win conditions use the three core strategic objectives. RED only loses when BLUE wins. BLUE loses when any loss condition triggers.",
    "strategic_objectives": {
      "ANNIHILATION": "Destroy all enemy combat assets",
      "RESOURCE_CONTROL": "Secure and hold designated resource nodes for required consecutive turns",
      "DECAPITATION": "Eliminate or capture enemy command node — Command Decapitation threshold event"
    },
    "win_loss_structure": {
      "BLUE_wins_when": "BLUE achieves its primary strategic objective",
      "BLUE_loses_when": "Any BLUE loss condition triggers — Economic Exhaustion, Supply Chain Collapse, Political Will Failure, Proxy Exhaustion, Survival Failure, Command Decapitation, Nuclear Threshold",
      "RED_wins_when": "BLUE loses — RED has no independent loss condition",
      "RED_loses_when": "BLUE achieves its primary strategic objective",
      "design_note": "RED plays to prevent BLUE success and trigger BLUE loss conditions. The game continues as long as BLUE loss conditions have not triggered and BLUE has not achieved its objective. Both sides keep taking turns until one condition resolves."
    },
    "entry_point_rule": "Each faction has one LAND entry node and one SEA entry node. All starting assets deploy from one of these two points on turn 1. Reinforcements and rebuilt assets enter only through these nodes.",
    "asset_count_range": "6-10 assets per faction scaled to faction economic power and scenario readiness.",
    "turn_structure": "28 turns. 6 hours per turn."
  },

